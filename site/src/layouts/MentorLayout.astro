---
// Standalone minimal layout for the password-gated mentor pages.
// Deliberately NOT the Starlight shell: these pages are StatiCrypt-encrypted at build
// time, and a self-contained page decrypts/renders cleanly with no client-side hydration.
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? 'מסמכי חופף';
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · חופף</title>
    <style>
      :root {
        --bg: #0b1018;
        --panel: #11192444;
        --text: #e8eef5;
        --muted: #9fb0c3;
        --accent: #56b8ff;
        --border: #24364f;
        --code-bg: #0e1726;
      }
      * { box-sizing: border-box; }
      html { background: var(--bg); }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
        line-height: 1.7;
      }
      .wrap { max-width: 56rem; margin: 0 auto; padding: 2.5rem 1.25rem 5rem; }
      .badge {
        display: inline-block;
        font-size: 0.8rem;
        color: var(--accent);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.15rem 0.7rem;
        margin-bottom: 1.5rem;
      }
      h1, h2, h3 { line-height: 1.3; }
      h1 { font-size: 1.9rem; margin: 0 0 1rem; }
      h2 { font-size: 1.35rem; margin: 2.2rem 0 0.8rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      h3 { font-size: 1.1rem; margin: 1.6rem 0 0.6rem; color: var(--accent); }
      a { color: var(--accent); }
      hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
      blockquote {
        margin: 1.2rem 0;
        padding: 0.6rem 1rem;
        border-inline-start: 3px solid var(--accent);
        background: var(--panel);
        border-radius: 0 6px 6px 0;
        color: var(--muted);
      }
      table { border-collapse: collapse; width: 100%; margin: 1.2rem 0; font-size: 0.95rem; }
      th, td { border: 1px solid var(--border); padding: 0.5rem 0.7rem; text-align: start; vertical-align: top; }
      th { background: var(--panel); }
      /* Code stays LTR on the RTL page (same idea as the main site's rtl-code.css). */
      code {
        background: var(--code-bg);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
        font-size: 0.9em;
        direction: ltr;
        unicode-bidi: isolate;
      }
      pre {
        background: var(--code-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
        direction: ltr;
        text-align: left;
      }
      pre code { background: none; padding: 0; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <span class="badge">מסמכי חופף · פרטי</span>
      <slot />
    </main>
  </body>
</html>
